# Obtain these from the Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# From `stripe listen --forward-to localhost:4242/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# Connected account country (ISO 3166-1 alpha-2) and settlement currency
CONNECTED_ACCOUNT_COUNTRY=US
CURRENCY=usd

# Public base URL used for onboarding and Checkout redirects
DOMAIN=http://localhost:4242

PORT=4242
